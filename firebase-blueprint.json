{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a user in the system.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "lab_tech", "student", "faculty"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Item": {
      "title": "Inventory Item",
      "description": "An item in the pharmacy lab inventory.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["glassware", "chemical", "equipment"] },
        "description": { "type": "string" },
        "quantity": { "type": "integer" },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "quantity", "createdAt", "updatedAt"]
    },
    "BorrowRecord": {
      "title": "Borrow Record",
      "description": "A record of an item being borrowed.",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "userId": { "type": "string" },
        "quantity": { "type": "integer" },
        "status": { "type": "string", "enum": ["borrowed", "returned", "overdue"] },
        "borrowDate": { "type": "string", "format": "date-time" },
        "returnDate": { "type": "string", "format": "date-time" }
      },
      "required": ["itemId", "userId", "quantity", "status", "borrowDate"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles. The document ID is the user's Auth uid."
    },
    "/items/{itemId}": {
      "schema": { "$ref": "#/entities/Item" },
      "description": "Inventory items."
    },
    "/borrowRecords/{recordId}": {
      "schema": { "$ref": "#/entities/BorrowRecord" },
      "description": "Records of borrowed items."
    }
  }
}
